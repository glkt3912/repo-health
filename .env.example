# repo-health 環境変数テンプレート
# このファイルをコピーして .env を作成し、実際の値を設定する
# $ cp .env.example .env

# 監査対象の GitHub ユーザー名
# config.yml の github.username より優先される
REPO_AUDIT_USERNAME=your-github-username

# しきい値（月数）— 変更しない場合はコメントアウトのまま
# REPO_AUDIT_STALE_MONTHS=6
# REPO_AUDIT_ARCHIVE_MONTHS=12

# レポートの保存先
# REPO_AUDIT_OUTPUT_DIR=~/repo-health-reports/

# 別の config.yml を使う場合
# REPO_AUDIT_CONFIG=/path/to/config.yml
